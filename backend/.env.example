# Server
PORT=5001

# MongoDB - Railway Production URI (Railway dashboard'dan alın, buraya yazmayın)
MONGODB_URI=mongodb://USER:PASSWORD@HOST:PORT/DBNAME?authSource=admin

# JWT Secret - Güçlü random bir değer üretin: `openssl rand -hex 64`
JWT_SECRET=REPLACE_WITH_256BIT_HEX_RANDOM

# Admin Credentials
# ADMIN_PASSWORD: bcrypt hash olarak saklanması önerilir (ADMIN_PASSWORD_HASH)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# HTTP API - Birincil Kaynak (Fiyat kaynağı)
PRICE_API_URL=http://example.com/api.php

# HTTP API - Yedek Kaynak
PRICE_API_URL_BACKUP=https://example.com/backup

# Polling Ayarları
POLL_INTERVAL=2000
FALLBACK_TIMEOUT=1800000

# Webhook Secret - Güçlü random: `openssl rand -hex 32`
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── MASAK Yaptırım Listesi Taraması ──
# Eşleşme eşiği (0–1). Yüksek = daha az yanlış pozitif, daha çok kaçak riski.
MASAK_MATCH_THRESHOLD=0.88
# Liste senkron periyodu (ms). Varsayılan 24 saat.
MASAK_SYNC_INTERVAL=86400000

# ── Otomatik çekim (HMB API adapter) ──
# Varsayılan true: backend her MASAK_SYNC_INTERVAL'da 4 listeyi MASAK'tan çeker
# (POST /portal/v2/masak/mvd/malvarligi-dondurulanlar). Devre dışı için: false
MASAK_AUTO_FETCH=true
# API base URL (override gerekirse). Varsayılan: https://masak.hmb.gov.tr
MASAK_API_BASE=https://masak.hmb.gov.tr

# Opsiyonel/geriye dönük: dosya tabanlı kaynaklar (CSV/Excel URL'leri). JSON dizi.
# Genelde boş kalır; otomatik çekim için MASAK_AUTO_FETCH yeterlidir.
# Örn: [{"url":"https://.../liste.csv","listCode":"6415_m5"}]
MASAK_LIST_URLS=[]
